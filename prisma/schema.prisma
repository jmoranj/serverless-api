generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Ticket {
  id          String          @id @default(uuid())
  title       String
  description String          @db.Text
  priority    Priority
  createdBy   String          @map("created_by")
  status      TicketStatus    @default(OPEN)
  createdAt   DateTime        @default(now()) @map("created_at")

  @@map("tickets")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}
