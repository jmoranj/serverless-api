{
  "scripts": {
    "predeploy": "npx prisma generate",
    "deploy": "serverless deploy --stage prod",
    "dev": "serverless offline",
    "migrate": "aws lambda invoke --function-name serverless-api-prod-migrate --payload '{}' --cli-binary-format raw-in-base64-out /tmp/migration.json && cat /tmp/migration.json",
    "migrate:local": "serverless invoke local --function migrate",
    "test": "vitest --ui",
    "test:watch": "vitest run --reporter=verbose"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/ui": "^4.1.4",
    "esbuild": "^0.27.7",
    "prisma": "^7.7.0",
    "serverless-offline": "^14.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/aws-lambda": "^8.10.161",
    "aws-lambda": "^1.0.7",
    "zod": "^4.3.6"
  }
}
